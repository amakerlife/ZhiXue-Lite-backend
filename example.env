FLASK_ENV=development # 环境配置，development 或 production

CAPTCHA_URL=          # 验证码服务地址

DEV_SECRET_KEY=       # 开发环境 Cookie 密钥
DEV_DATABASE_URL=     # 开发环境数据库连接字符串

PROD_SECRET_KEY=      # 生产环境 Cookie 密钥
PROD_DATABASE_URL=    # 生产环境数据库连接字符串

LOG_LEVEL=INFO        # 日志级别
LOG_DIR=              # 日志保存目录路径，留空则使用项目根目录下的 logs 文件夹